{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Block if file contains hardcoded API keys (sk-ant-*, sk-*, amk_*). Warn: 'Use environment variables instead.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Warn if command output contains leaked API keys."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "doctor|reviewer|stack-reviewer|ux-reviewer|brainstormer|grillme|documenter|debugger|coach",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.sh"
          }
        ]
      }
    ]
  }
}
