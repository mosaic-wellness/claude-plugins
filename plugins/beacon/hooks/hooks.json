{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Block if file contains hardcoded API keys (sk-ant-*, sk-*, amk_*). Warn: 'Use environment variables instead.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Warn if command output contains leaked API keys."
          }
        ]
      }
    ],
    "Skill": [
      {
        "matcher": "beacon",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.sh \"$ARGUMENTS\""
          }
        ]
      }
    ]
  }
}
